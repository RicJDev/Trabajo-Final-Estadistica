---
export interface Props {
  title: string
  description: string
  total: number
}

const { title, description, total } = Astro.props
---

<section class="mb-8">
  <h2 class="text-2xl text-gray-900 mb-3">{title}</h2>

  <p class="text-gray-700 leading-relaxed max-w-[800px]">{description}</p>
  <p class="mt-3 text-[0.95rem] text-gray-500">
    <strong>{total}</strong> respuestas registradas
  </p>
</section>
