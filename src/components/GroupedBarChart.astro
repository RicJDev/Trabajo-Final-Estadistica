---
import type { GroupedBarChartProps } from '../types'

type Props = GroupedBarChartProps

const { labels, datasets, titulo } = Astro.props
const chartData = JSON.stringify({ labels, datasets })
const chartHeight = Math.max(300, labels.length * 35)
const containerHeight = chartHeight + 60
---

<div
  class="bg-white border border-gray-200 rounded-lg p-6 w-full"
  style={`min-height: ${containerHeight}px`}
>
  <h3 class="text-base font-semibold text-gray-900 mb-4">{titulo}</h3>
  <div
    class="relative w-full"
    style={`height: ${chartHeight}px`}
  >
    <canvas
      class="grafico-barras-agrupadas"
      data-chart={chartData}
    ></canvas>
  </div>
</div>

<script>
  import { createGroupedBarChart } from '../utils/createChart'
  import type { GroupedBarChartData } from '../types'

  document.querySelectorAll<HTMLCanvasElement>('.grafico-barras-agrupadas').forEach((canvas) => {
    const data = JSON.parse(canvas.dataset.chart!) as GroupedBarChartData
    const title = canvas.closest('[class*="bg-white"]')?.querySelector('h3')?.textContent ?? ''
    createGroupedBarChart(canvas, data, title)
  })
</script>
