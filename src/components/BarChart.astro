---
import type { BarChartProps } from '../types'

type Props = BarChartProps

const { datos, titulo, descripcion } = Astro.props
const chartData = JSON.stringify(datos)
const chartHeight = Math.max(250, datos.length * 28)
const containerHeight = chartHeight + 100
---

<div
  class="bg-white border border-gray-200 rounded-lg p-6 w-full"
  style={`min-height: ${containerHeight}px`}
>
  <h3 class="text-base font-semibold text-gray-900 mb-4">{titulo}</h3>
  {descripcion && <p class="text-sm text-gray-500 mb-4 leading-relaxed">{descripcion}</p>}
  <div
    class="relative w-full"
    style={`height: ${chartHeight}px`}
  >
    <canvas
      class="grafico-barras"
      data-chart={chartData}
    ></canvas>
  </div>
</div>

<script>
  import { createBarChart } from '../utils/createChart'
  import type { DataPoint } from '../types'

  document.querySelectorAll<HTMLCanvasElement>('.grafico-barras').forEach((canvas) => {
    const data = JSON.parse(canvas.dataset.chart!) as DataPoint[]
    const title = canvas.closest('[class*="bg-white"]')?.querySelector('h3')?.textContent ?? ''
    createBarChart(canvas, data, title)
  })
</script>
