---
export interface Props {
  datos: { label: string; value: number }[]
  titulo: string
  descripcion?: string
}

const { datos, titulo, descripcion } = Astro.props
const chartData = JSON.stringify(datos)
const chartHeight = Math.max(250, datos.length * 28)
const containerHeight = chartHeight + 100
---

<div class="chart-container" style={`min-height: ${containerHeight}px`}>
  <h3>{titulo}</h3>
  {descripcion && <p class="chart-desc">{descripcion}</p>}
  <div class="chart-wrapper" style={`height: ${chartHeight}px`}>
    <canvas
      class="grafico-barras"
      data-chart={chartData}
    ></canvas>
  </div>
</div>

<script>
  import { createBarChart } from '../utils/createChart'

  document.querySelectorAll<HTMLCanvasElement>('.grafico-barras').forEach((canvas) => {
    const data = JSON.parse(canvas.dataset.chart!)
    const title = canvas.closest('.chart-container')?.querySelector('h3')?.textContent ?? ''
    createBarChart(canvas, data, title)
  })
</script>

<style>
  .chart-container {
    background: #fff;
    border: 1px solid #e5e7eb;
    border-radius: 8px;
    padding: 1.5rem;
    width: 100%;
  }

  .chart-wrapper {
    position: relative;
    width: 100%;
  }

  h3 {
    font-size: 1rem;
    font-weight: 600;
    color: #111827;
    margin-bottom: 1rem;
  }

  .chart-desc {
    font-size: 0.875rem;
    color: #6b7280;
    margin-bottom: 1rem;
    line-height: 1.5;
  }
</style>
