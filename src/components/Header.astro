---
import { Image } from 'astro:assets'
import UNERGLogo from '../assets/logo-unerg.png'
---

<header>
  <div class="header-inner">
    <span class="logo">Encuesta AIS 2026</span>
    <Image
      src={UNERGLogo}
      class='logo-img'
      alt="Logo de la Universidad Nacional Experimental Rómulo Gallegos"
    />
  </div>
</header>

<style>
  header {
    border-bottom: 1px solid #e5e7eb;
    background: #fff;
  }

  .header-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 1.5rem;
  }

  .logo-img {
    max-width: 120px;
  }

  .logo {
    font-size: 1.25rem;
    font-weight: 700;
    color: #111827;
  }
</style>
