---
import InsightsPanel from '../InsightsPanel.astro'
import type { StudentInsights } from '../../types'

export interface Props {
  insights: StudentInsights
}

const { insights } = Astro.props
---

<section
  id="resumen"
  class="max-w-6xl mx-auto px-6 py-8 pb-12"
>
  <InsightsPanel insights={insights} />
</section>
