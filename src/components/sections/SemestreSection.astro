---
import BarChart from '../BarChart.astro'
import { toEntries } from '../../utils/data'
import type { LabelValueData } from '../../types'

export interface Props {
  data: LabelValueData
}

const { data } = Astro.props
---

<section
  id="semestre"
  class="max-w-6xl mx-auto px-6 py-8 pb-12"
>
  <h2 class="text-2xl font-bold text-gray-900 mb-4">Distribución por Semestre</h2>
  <div class="grid grid-cols-[repeat(auto-fill,minmax(400px,1fr))] gap-6">
    <BarChart
      datos={toEntries(data)}
      titulo="¿Qué año o semestre estás cursando actualmente?"
      descripcion="La mayoría de los encuestados se concentra en los semestres intermedios (4to a 6to), con picos notables en 4to semestre y 2do semestre."
    />
  </div>
</section>
