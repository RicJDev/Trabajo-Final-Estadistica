---
export interface Props {
  datos: { label: string; value: number }[]
  titulo: string
  descripcion?: string
}

const { datos, titulo, descripcion } = Astro.props
const chartData = JSON.stringify(datos)
---

<div class="bg-white border border-gray-200 rounded-lg p-6 w-full">
  <h3 class="text-base font-semibold text-gray-900 mb-4">{titulo}</h3>
  {descripcion && <p class="text-sm text-gray-500 mb-4 leading-relaxed">{descripcion}</p>}
  <canvas
    class="grafico-pastel"
    data-chart={chartData}
  ></canvas>
</div>

<script>
  import { createPieChart } from '../utils/createChart'

  document.querySelectorAll<HTMLCanvasElement>('.grafico-pastel').forEach((canvas) => {
    const datos = JSON.parse(canvas.dataset.chart!)
    const titulo = canvas.closest('[class*="bg-white"]')?.querySelector('h3')?.textContent ?? ''
    createPieChart(canvas, datos, titulo)
  })
</script>
