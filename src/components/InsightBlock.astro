---
export interface Props {
  blue?: boolean
  highlighted: string | number
}

const { highlighted, blue } = Astro.props

const blockClass = blue
  ? 'bg-blue-50 border border-blue-200 rounded-lg p-5 flex flex-col gap-2'
  : 'bg-white border border-gray-200 rounded-lg p-5 flex flex-col gap-2'
---

<div class={blockClass}>
  <span class="text-xl font-bold text-blue-700 leading-tight">{highlighted}</span>
  <span class="text-sm text-gray-500 leading-relaxed">
    <slot />
  </span>
</div>
