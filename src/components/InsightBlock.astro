---
export interface Props {
  highlighted: string | number
  accent?: 'blue' | 'green' | 'purple' | 'amber' | 'rose'
}

const { highlighted, accent = 'blue' } = Astro.props

const palette: Record<string, { border: string; text: string }> = {
  blue: { border: 'border-l-blue-500', text: 'text-blue-700' },
  green: { border: 'border-l-emerald-500', text: 'text-emerald-700' },
  purple: { border: 'border-l-violet-500', text: 'text-violet-700' },
  amber: { border: 'border-l-amber-500', text: 'text-amber-700' },
  rose: { border: 'border-l-rose-500', text: 'text-rose-700' },
}
const p = palette[accent]
const cardClass = `bg-gray-50 border border-gray-200 border-l-4 ${p.border} rounded-lg p-5 flex flex-col gap-1.5 group hover:shadow-md hover:-translate-y-0.5 transition-all duration-200 cursor-default h-full`
const numClass = `text-2xl text-balance font-bold ${p.text} leading-tight tracking-tight h-full`
---

<div class={cardClass}>
  <span class={numClass}>{highlighted}</span>
  <span class="text-xs text-gray-500 leading-relaxed"><slot /></span>
</div>
