---
import InsightBlock from './InsightBlock.astro'

export interface Props {
  insights: {
    estudiantes: {
      total: number
      top_lenguajes: { label: string; count: number }[]
      top_frameworks: { label: string; count: number }[]
      top_areas: { label: string; count: number }[]
      distribucion_horas: { label: string; count: number }[]
      factor_empleo: { label: string; count: number }[]
      impacto_ia: { label: string; count: number }[]
      frecuencia_ia: { label: string; count: number }[]
      meta_graduacion: { label: string; count: number }[]
      uso_diario_ia_pct: number
      impacto_positivo_ia_pct: number
    }
  }
}

const { insights } = Astro.props
const e = insights.estudiantes
---

<div class="grid grid-cols-[repeat(auto-fill,minmax(280px,1fr))] gap-4">
  <InsightBlock
    blue
    highlighted={e.total}
  >
    Estudiantes encuestados
  </InsightBlock>

  <InsightBlock highlighted={e.top_lenguajes[0]?.label}>
    Lenguaje más popular - {e.top_lenguajes[0]?.count} respuestas
  </InsightBlock>

  <InsightBlock highlighted={e.top_frameworks[0]?.label}
    >Framework más popular — {e.top_frameworks[0]?.count} respuestas</InsightBlock
  >

  <InsightBlock highlighted={e.top_areas[0]?.label}>
    Área más aspirada — {e.top_areas[0]?.count} respuestas
  </InsightBlock>

  <InsightBlock highlighted={`${e.uso_diario_ia_pct}%`}>
    Usan IA a diario
  </InsightBlock>

  <InsightBlock highlighted={`${e.impacto_positivo_ia_pct}%`}>
    Creen que IA será herramienta obligatoria
  </InsightBlock>

  <InsightBlock highlighted={e.meta_graduacion[0]?.label}>
    Meta principal al graduarse — {e.meta_graduacion[0]?.count} respuestas
  </InsightBlock>

  <InsightBlock highlighted={e.factor_empleo[0]?.label}>
    Factor más valorado para empleo — {e.factor_empleo[0]?.count} respuestas
  </InsightBlock>

  <InsightBlock highlighted={e.distribucion_horas[0]?.label}>
    Horas autónomas más comunes — {e.distribucion_horas[0]?.count} respuestas
  </InsightBlock>
</div>
