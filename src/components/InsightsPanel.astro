---
import InsightBlock from './InsightBlock.astro'

export interface Props {
  insights: {
    estudiantes: {
      total: number
      top_lenguajes: { label: string; count: number }[]
      top_frameworks: { label: string; count: number }[]
      top_areas: { label: string; count: number }[]
      distribucion_horas: { label: string; count: number }[]
      factor_empleo: { label: string; count: number }[]
      impacto_ia: { label: string; count: number }[]
      frecuencia_ia: { label: string; count: number }[]
      meta_graduacion: { label: string; count: number }[]
      uso_diario_ia_pct: number
      impacto_positivo_ia_pct: number
    }
  }
}

const { insights } = Astro.props
const e = insights.estudiantes
---

<div class="grid grid-cols-[repeat(auto-fill,minmax(280px,1fr))] gap-4">
  <InsightBlock
    blue
    highlighted={e.total}
  >
    Estudiantes encuestados
  </InsightBlock>

  <InsightBlock highlighted={e.top_lenguajes[0]?.label}>
    Lenguaje más popular - {e.top_lenguajes[0]?.count} respuestas
  </InsightBlock>

  <InsightBlock highlighted={e.top_frameworks[0]?.label}
    >Framework más popular — {e.top_frameworks[0]?.count} respuestas</InsightBlock
  >

  <div class="bg-white border border-gray-200 rounded-lg p-5 flex flex-col gap-2">
    <span class="text-xl font-bold text-blue-700 leading-tight">{e.top_areas[0]?.label}</span>
    <span class="text-sm text-gray-500 leading-relaxed">Área más aspirada — {e.top_areas[0]?.count} respuestas</span>
  </div>

  <div class="bg-white border border-gray-200 rounded-lg p-5 flex flex-col gap-2">
    <span class="text-xl font-bold text-blue-700 leading-tight">{e.uso_diario_ia_pct}%</span>
    <span class="text-sm text-gray-500 leading-relaxed">Usan IA a diario</span>
  </div>

  <div class="bg-white border border-gray-200 rounded-lg p-5 flex flex-col gap-2">
    <span class="text-xl font-bold text-blue-700 leading-tight">{e.impacto_positivo_ia_pct}%</span>
    <span class="text-sm text-gray-500 leading-relaxed">Creen que IA será herramienta obligatoria</span>
  </div>

  <div class="bg-white border border-gray-200 rounded-lg p-5 flex flex-col gap-2">
    <span class="text-xl font-bold text-blue-700 leading-tight">{e.meta_graduacion[0]?.label}</span>
    <span class="text-sm text-gray-500 leading-relaxed"
      >Meta principal al graduarse — {e.meta_graduacion[0]?.count} respuestas</span
    >
  </div>

  <div class="bg-white border border-gray-200 rounded-lg p-5 flex flex-col gap-2">
    <span class="text-xl font-bold text-blue-700 leading-tight">{e.factor_empleo[0]?.label}</span>
    <span class="text-sm text-gray-500 leading-relaxed"
      >Factor más valorado para empleo — {e.factor_empleo[0]?.count} respuestas</span
    >
  </div>

  <div class="bg-white border border-gray-200 rounded-lg p-5 flex flex-col gap-2">
    <span class="text-xl font-bold text-blue-700 leading-tight">{e.distribucion_horas[0]?.label}</span>
    <span class="text-sm text-gray-500 leading-relaxed"
      >Horas autónomas más comunes — {e.distribucion_horas[0]?.count} respuestas</span
    >
  </div>
</div>
