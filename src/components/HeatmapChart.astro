---
export interface Props {
  xLabels: string[]
  yLabels: string[]
  data: number[][]
  titulo: string
  descripcion?: string
}

const { xLabels, yLabels, data, titulo, descripcion } = Astro.props

const maxVal = Math.max(1, ...data.flat())

function color(value: number): string {
  const intensity = value / maxVal
  if (intensity === 0) return '#f8fafc'
  if (intensity <= 0.25) return '#bfdbfe'
  if (intensity <= 0.5) return '#60a5fa'
  if (intensity <= 0.75) return '#3b82f6'
  return '#1d4ed8'
}
---

<div class="bg-white border border-gray-200 rounded-lg p-6 w-full max-sm:p-4">
  <h3 class="text-base font-semibold text-gray-900 mb-4">{titulo}</h3>
  {descripcion && <p class="text-sm text-gray-500 mb-4 leading-relaxed">{descripcion}</p>}
  <div class="overflow-x-auto -mx-6 px-6 w-[calc(100%+3rem)] max-sm:-mx-4 max-sm:px-4 max-sm:w-[calc(100%+2rem)]">
    <table class="border-collapse w-full text-sm">
      <thead>
        <tr>
          <th class="text-left p-2 px-3 font-medium text-gray-700 max-sm:p-1.5 max-sm:px-2 max-sm:text-[0.8rem]"></th>
          {xLabels.map((xl) => <th class="font-semibold text-gray-500 text-xs uppercase tracking-wider border-b-2 border-gray-200 text-left p-2 px-3 max-sm:p-1.5 max-sm:px-2 max-sm:text-[0.65rem]">{xl}</th>)}
        </tr>
      </thead>
      <tbody>
        {
          data.map((row, i) => (
            <tr>
              <th class=" bg-white z-1 min-w-[120px] text-left p-2 px-3 font-medium text-gray-700 max-sm:min-w-[100px] max-sm:p-1.5 max-sm:px-2 max-sm:text-[0.8rem]">{yLabels[i]}</th>
              {row.map((v) => (
                <td class="text-center p-2 px-3 font-semibold text-[#1e3a5f] border border-gray-200 max-sm:p-1.5 max-sm:px-2 max-sm:text-[0.8rem] max-sm:min-w-[44px]" style={{ backgroundColor: color(v) }}>{v}</td>
              ))}
            </tr>
          ))
        }
      </tbody>
    </table>
  </div>
</div>
