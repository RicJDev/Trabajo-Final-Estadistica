---
import '../styles/global.css'
import Layout from '../layouts/Layout.astro'

import BarChart from '../components/BarChart.astro'
import PieChart from '../components/PieChart.astro'
import GroupedBarChart from '../components/GroupedBarChart.astro'
import HeatmapChart from '../components/HeatmapChart.astro'

import compArea from '../../data/graficos_json/comp_area.json'
import compFrameworks from '../../data/graficos_json/comp_frameworks.json'
import compFrecuenciaIa from '../../data/graficos_json/comp_frecuencia_ia.json'
import compHerramientas from '../../data/graficos_json/comp_herramientas.json'
import compImpactoIa from '../../data/graficos_json/comp_impacto_ia.json'
import compLenguajes from '../../data/graficos_json/comp_lenguajes.json'
import egrAniosEgresado from '../../data/graficos_json/egr_anios_egresado.json'
import egrFactorContratacion from '../../data/graficos_json/egr_factor_contratacion.json'
import egrFrameworks from '../../data/graficos_json/egr_frameworks.json'
import egrFrecuenciaIa from '../../data/graficos_json/egr_frecuencia_ia.json'
import egrHerramientas from '../../data/graficos_json/egr_herramientas.json'
import egrImpactoIa from '../../data/graficos_json/egr_impacto_ia.json'
import egrIngresos from '../../data/graficos_json/egr_ingresos.json'
import egrLenguajes from '../../data/graficos_json/egr_lenguajes.json'
import egrNivelIngles from '../../data/graficos_json/egr_nivel_ingles.json'
import egrRolActual from '../../data/graficos_json/egr_rol_actual.json'
import egrTiempoEmpleo from '../../data/graficos_json/egr_tiempo_empleo.json'
import estAreaAspirada from '../../data/graficos_json/est_area_aspirada.json'
import estFactorEmpleo from '../../data/graficos_json/est_factor_empleo.json'
import estFrameworks from '../../data/graficos_json/est_frameworks.json'
import estFrecuenciaIa from '../../data/graficos_json/est_frecuencia_ia.json'
import estHerramientas from '../../data/graficos_json/est_herramientas.json'
import estHorasAutonomas from '../../data/graficos_json/est_horas_autonomas.json'
import estImpactoIa from '../../data/graficos_json/est_impacto_ia.json'
import estLenguajes from '../../data/graficos_json/est_lenguajes.json'
import estMetaGraduacion from '../../data/graficos_json/est_meta_graduacion.json'
import heatmap from '../../data/graficos_json/heatmap_lenguajes_frameworks.json'

function toEntries(labels: string[], values: number[]) {
  return labels.map((label, i) => ({ label, value: values[i] }))
}
---

<Layout>
  <div class="debug-page">
    <h1>Debug — Vista de todos los gráficos</h1>

    <section>
      <h2>Estudiantes</h2>
      <div class="grid-2">
        <BarChart datos={toEntries(estLenguajes.labels, estLenguajes.values)} titulo="Lenguajes más usados" />
        <BarChart datos={toEntries(estHerramientas.labels, estHerramientas.values)} titulo="Herramientas que dominan" />
        <BarChart datos={toEntries(estFrameworks.labels, estFrameworks.values)} titulo="Frameworks que conocen" />
        <BarChart datos={toEntries(estAreaAspirada.labels, estAreaAspirada.values)} titulo="Área aspirada" />
        <BarChart datos={toEntries(estHorasAutonomas.labels, estHorasAutonomas.values)} titulo="Horas autónomas por semana" />
        <PieChart datos={toEntries(estFactorEmpleo.labels, estFactorEmpleo.values)} titulo="Factor más importante para empleo" />
        <PieChart datos={toEntries(estImpactoIa.labels, estImpactoIa.values)} titulo="Percepción del impacto de IA" />
        <PieChart datos={toEntries(estMetaGraduacion.labels, estMetaGraduacion.values)} titulo="Meta al graduarse" />
        <PieChart datos={toEntries(estFrecuenciaIa.labels, estFrecuenciaIa.values)} titulo="Frecuencia de uso de IA" />
      </div>
    </section>

    <section>
      <h2>Egresados</h2>
      <div class="grid-2">
        <BarChart datos={toEntries(egrLenguajes.labels, egrLenguajes.values)} titulo="Lenguajes que usan" />
        <BarChart datos={toEntries(egrHerramientas.labels, egrHerramientas.values)} titulo="Herramientas que usan" />
        <BarChart datos={toEntries(egrFrameworks.labels, egrFrameworks.values)} titulo="Frameworks que usan" />
        <BarChart datos={toEntries(egrRolActual.labels, egrRolActual.values)} titulo="Rol actual" />
        <BarChart datos={toEntries(egrAniosEgresado.labels, egrAniosEgresado.values)} titulo="Años desde egreso" />
        <BarChart datos={toEntries(egrTiempoEmpleo.labels, egrTiempoEmpleo.values)} titulo="Tiempo en encontrar empleo" />
        <BarChart datos={toEntries(egrNivelIngles.labels, egrNivelIngles.values)} titulo="Nivel de inglés" />
        <PieChart datos={toEntries(egrFactorContratacion.labels, egrFactorContratacion.values)} titulo="Factor clave de contratación" />
        <PieChart datos={toEntries(egrImpactoIa.labels, egrImpactoIa.values)} titulo="Impacto de IA en su trabajo" />
        <PieChart datos={toEntries(egrFrecuenciaIa.labels, egrFrecuenciaIa.values)} titulo="Frecuencia de uso de IA" />
      </div>
    </section>

    <section>
      <h2>Comparativas Estudiantes vs Egresados</h2>
      <div class="grid-2">
        <GroupedBarChart
          labels={compLenguajes.labels}
          datasets={[compLenguajes.dataset1, compLenguajes.dataset2]}
          titulo="Lenguajes: Estudiantes vs Egresados"
        />
        <GroupedBarChart
          labels={compArea.labels}
          datasets={[compArea.dataset1, compArea.dataset2]}
          titulo="Área de interés: Estudiantes vs Egresados"
        />
        <GroupedBarChart
          labels={compFrameworks.labels}
          datasets={[compFrameworks.dataset1, compFrameworks.dataset2]}
          titulo="Frameworks: Estudiantes vs Egresados"
        />
        <GroupedBarChart
          labels={compHerramientas.labels}
          datasets={[compHerramientas.dataset1, compHerramientas.dataset2]}
          titulo="Herramientas: Estudiantes vs Egresados"
        />
        <GroupedBarChart
          labels={compImpactoIa.labels}
          datasets={[compImpactoIa.dataset1, compImpactoIa.dataset2]}
          titulo="Impacto de IA: Estudiantes vs Egresados"
        />
        <GroupedBarChart
          labels={compFrecuenciaIa.labels}
          datasets={[compFrecuenciaIa.dataset1, compFrecuenciaIa.dataset2]}
          titulo="Frecuencia de IA: Estudiantes vs Egresados"
        />
      </div>
    </section>

    <section>
      <h2>Heatmap</h2>
      <div class="grid-1">
        <HeatmapChart
          xLabels={heatmap.xLabels}
          yLabels={heatmap.yLabels}
          data={heatmap.data}
          titulo={heatmap.title}
        />
      </div>
    </section>
  </div>
</Layout>

<style>
  .debug-page {
    padding: 2rem;
    max-width: 1200px;
    margin: 0 auto;
  }

  h1 {
    font-size: 1.5rem;
    margin-bottom: 2rem;
    color: #111827;
  }

  section {
    margin-bottom: 3rem;
  }

  section > h2 {
    font-size: 1.25rem;
    font-weight: 600;
    color: #374151;
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid #e5e7eb;
  }

  .grid-2 {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(400px, 1fr));
    gap: 1.5rem;
  }

  .grid-1 {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }
</style>
