---
import Layout from '../layouts/Layout.astro'
import Header from '../components/Header.astro'
import Footer from '../components/Footer.astro'
import HeroSection from '../components/sections/HeroSection.astro'
import ResumenSection from '../components/sections/ResumenSection.astro'
import { loadJSON } from '../utils/data'
import type { StudentInsights } from '../types'

const insights = loadJSON<StudentInsights>('insights.json')
---

<Layout>
  <Header slot="header" />
  <Footer slot="footer" />

  <div class="max-w-6xl mx-auto px-6 py-10 min-h-dvh grid grid-cols-1 lg:grid-cols-5 gap-12 items-center">
    <div class="lg:col-span-2 lg:sticky lg:top-24 lg:self-start flex flex-col gap-8">
      <HeroSection />
      <div class="flex md:flex-row flex-col gap-3">
        <div class="flex-1 bg-gray-50 border border-gray-200 border-l-4 border-l-blue-500 rounded-lg p-4">
          <span class="block text-2xl font-bold text-blue-700 leading-tight tracking-tight">{insights.estudiantes.total}</span>
          <span class="block text-xs text-gray-500 leading-relaxed mt-0.5">Estudiantes encuestados</span>
        </div>
        <div class="flex-1 bg-gray-50 border border-gray-200 border-l-4 border-l-emerald-500 rounded-lg p-4">
          <span class="block text-2xl font-bold text-emerald-700 leading-tight tracking-tight">{insights.egresados.total}</span>
          <span class="block text-xs text-gray-500 leading-relaxed mt-0.5">Egresados encuestados</span>
        </div>
      </div>
    </div>
    <div class="lg:col-span-3">
      <ResumenSection insights={insights} />
    </div>
  </div>
</Layout>
