---
import Layout from '../layouts/Layout.astro'
import Header from '../components/Header.astro'
import Footer from '../components/Footer.astro'
---

<Layout>
  <Header slot="header" />
  <Footer slot="footer" />

  <section class="hero">
    <h1>Resultados de la Encuesta AIS 2026</h1>
    <p>Visualización de datos recolectados de estudiantes y egresados de el Área de Ingeniería en Sistemas (AIS) de la Universidad Nacional Experimental Rómulo Gallegos</p>
  </section>
</Layout>

<style>
  .hero {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 3rem 1.5rem;
    gap: 0.75rem;
  }

  h1 {
    font-size: 2rem;
    color: #111827;
  }

  .hero p {
    font-size: 1.125rem;
    color: #6b7280;
    max-width: 600px;
  }
</style>
