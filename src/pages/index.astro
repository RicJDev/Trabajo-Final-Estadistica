---
import Layout from '../layouts/Layout.astro'
import Header from '../components/Header.astro'
import Footer from '../components/Footer.astro'
import HeroSection from '../components/sections/HeroSection.astro'
import ResumenSection from '../components/sections/ResumenSection.astro'
import { loadJSON } from '../utils/data'
import type { StudentInsights } from '../types'

const insights = loadJSON<StudentInsights>('insights.json')
---

<Layout>
  <Header slot="header" />
  <Footer slot="footer" />

  <HeroSection />
  <ResumenSection insights={insights} />
</Layout>
